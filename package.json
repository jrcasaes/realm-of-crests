{
  "name": "realm-of-crests",
  "type": "module",
  "version": "1.8.3",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "astro preview",
    "validate:canon": "node scripts/validate-phase0.mjs",
    "validate:experience": "node scripts/validate-phase1.mjs",
    "validate:journey": "node scripts/validate-phase2.mjs",
    "validate:guardians": "node scripts/validate-phase3.mjs",
    "validate:pilgrimage": "node scripts/validate-phase4.mjs",
    "validate:journal": "node scripts/validate-phase5.mjs",
    "validate:release": "node scripts/validate-phase6.mjs",
    "validate:continuity": "node scripts/validate-phase7.mjs",
    "validate:vestiges": "node scripts/validate-phase7-1-1.mjs",
    "validate:legibility": "node scripts/validate-phase7-1-2.mjs",
    "validate:portrait-clarity": "node scripts/validate-phase7-1-3.mjs",
    "audit:dist": "node scripts/audit-dist.mjs",
    "validate": "npm run validate:canon && npm run validate:experience && npm run validate:journey && npm run validate:guardians && npm run validate:pilgrimage && npm run validate:journal && npm run validate:release && npm run validate:continuity && npm run validate:vestiges && npm run validate:legibility && npm run validate:portrait-clarity",
    "check": "npm run validate && npm run build && npm run audit:dist"
  },
  "devDependencies": {
    "astro": "^7.1.1"
  }
}
