---
interface AtlasEntry {
  mapNumber: number;
  x: number;
  y: number;
  realm: {
    slug: string;
    realm: string;
    trueName: string;
    essence: string;
    fervor: string;
    gravity: string;
    temple: string;
    biome: string;
    panoramaAsset: string;
  };
  guardian: {
    slug: string;
    name: string;
    epithet: string;
  };
}

interface Props {
  entries: AtlasEntry[];
  base: string;
}

const { entries, base } = Astro.props;
const initial = entries[0];
const atlasPanoramaPath = (asset: string, width: 960 | 1536) => {
  const stem = asset.replace(/\.[^.]+$/, '');
  return `${base}/assets/atlas/realms/${width}/${stem}.webp`;
};
const atlasData = entries.map(({ mapNumber, x, y, realm, guardian }) => {
  const panorama960 = atlasPanoramaPath(realm.panoramaAsset, 960);
  const panorama1536 = atlasPanoramaPath(realm.panoramaAsset, 1536);
  return {
    mapNumber,
    x,
    y,
    slug: realm.slug,
    realm: realm.realm,
    trueName: realm.trueName,
    essence: realm.essence,
    fervor: realm.fervor,
    gravity: realm.gravity,
    temple: realm.temple,
    biome: realm.biome,
    guardian: guardian.name,
    guardianSlug: guardian.slug,
    epithet: guardian.epithet,
    panorama: panorama960,
    panoramaSrcset: `${panorama960} 960w, ${panorama1536} 1536w`,
    emblem: `${base}/assets/atlas/emblems/emblem_${realm.slug}.webp`,
    realmHref: `${base}/reinos/${realm.slug}/`,
    guardianHref: `${base}/guardioes/${guardian.slug}/`,
  };
});
const initialPanorama = atlasData[0].panorama;
const initialPanoramaSrcset = atlasData[0].panoramaSrcset;
const initialEmblem = atlasData[0].emblem;
const serializedAtlas = JSON.stringify(atlasData).replace(/</g, '\\u003c');
---

<section class="immersive-atlas" id="atlas-explorer" data-immersive-atlas aria-labelledby="atlas-explorer-title">
  <header class="atlas-command">
    <div>
      <span class="rubric">instrumento cartográfico · interação canônica</span>
      <h2 id="atlas-explorer-title">O CONTINENTE RESPONDE</h2>
    </div>
    <div class="atlas-command-status" aria-live="polite" aria-atomic="true">
      <span>território em leitura</span>
      <strong id="atlas-live-status">01 · {initial.realm.realm}</strong>
    </div>
  </header>

  <div class="atlas-workspace">
    <div class="atlas-map-column">
      <div
        class="atlas-map-viewport"
        id="atlas-map-viewport"
        tabindex="0"
        aria-label="Mapa explorável dos dezenove Reinos. Use os marcadores ou o índice territorial."
        aria-describedby="atlas-map-instructions"
      >
        <div class="atlas-map-canvas" id="atlas-map-canvas">
          <img
            id="atlas-map-image"
            src={`${base}/assets/maps/map_continent.webp`}
            data-hires={`${base}/assets/maps/map_continent_2x.webp`}
            alt="Mapa Canônico do Continente de Realm of Crests, com dezenove Reinos, Solo Ancestral, Caminhos Sagrados e Fronteira da Ruína"
            width="1536"
            height="1024"
            draggable="false"
            decoding="async"
          />
          <nav class="atlas-pins" aria-label="Marcadores dos Reinos">
            {entries.map(({ mapNumber, x, y, realm }, index) => (
              <button
                class="atlas-pin"
                type="button"
                style={`--pin-x:${x}%;--pin-y:${y}%;`}
                data-atlas-index={index}
                aria-label={`${String(mapNumber).padStart(2, '0')} · ${realm.realm}. Exibir dossiê.`}
                aria-pressed={index === 0 ? 'true' : 'false'}
              >
                <span aria-hidden="true">{String(mapNumber).padStart(2, '0')}</span>
                <strong aria-hidden="true">{realm.realm}</strong>
              </button>
            ))}
          </nav>
        </div>

        <div class="atlas-map-vignette" aria-hidden="true"></div>

        <div class="atlas-map-controls" aria-label="Controles do mapa">
          <button type="button" id="atlas-zoom-in" aria-label="Aproximar mapa" title="Aproximar">+</button>
          <button type="button" id="atlas-zoom-out" aria-label="Afastar mapa" title="Afastar">−</button>
          <button type="button" id="atlas-zoom-reset" aria-label="Restaurar enquadramento" title="Restaurar enquadramento">⌖</button>
        </div>

        <p class="atlas-map-instructions" id="atlas-map-instructions">
          <span class="desktop-instruction">CTRL + RODA PARA APROXIMAR · ARRASTE QUANDO AMPLIADO</span>
          <span class="touch-instruction">TOQUE NOS SELOS · USE OS CONTROLES PARA APROXIMAR</span>
        </p>
      </div>

      <div class="atlas-territory-index">
        <header>
          <span class="rubric">índice territorial</span>
          <span><b id="atlas-progress">01</b> / 19</span>
        </header>
        <div class="atlas-territory-list" role="listbox" aria-label="Selecionar um Reino">
          {entries.map(({ mapNumber, realm }, index) => (
            <button
              type="button"
              role="option"
              aria-selected={index === 0 ? 'true' : 'false'}
              data-atlas-list-index={index}
            >
              <small>{String(mapNumber).padStart(2, '0')}</small>
              <strong>{realm.realm}</strong>
            </button>
          ))}
        </div>
      </div>
    </div>

    <aside class="atlas-dossier" id="atlas-dossier" aria-labelledby="atlas-dossier-title">
      <figure class="atlas-dossier-visual">
        <div class="atlas-dossier-scene" id="atlas-dossier-scene">
          <img
            class="atlas-dossier-panorama"
            id="atlas-panorama"
            src={initialPanorama}
            srcset={initialPanoramaSrcset}
            sizes="(min-width: 1080px) 360px, 96vw"
            alt={`Panorama editorial de ${initial.realm.trueName}`}
            width="1536"
            height="659"
            fetchpriority="high"
            decoding="async"
          />
          <div class="atlas-dossier-visual-wash" aria-hidden="true"></div>
          <img
            class="atlas-dossier-emblem"
            id="atlas-emblem"
            src={initialEmblem}
            alt=""
            width="256"
            height="256"
            decoding="async"
            onerror={`this.onerror=null;this.src='${base}/assets/emblems/placeholder.svg'`}
          />
        </div>
        <figcaption>INTERPRETAÇÃO EDITORIAL · APROVADA PARA O SITE</figcaption>
      </figure>

      <div class="atlas-dossier-body">
        <header class="atlas-dossier-heading">
          <span class="rubric" id="atlas-folio">fólio territorial 01</span>
          <h3 id="atlas-dossier-title">{initial.realm.trueName}</h3>
          <p id="atlas-epithet">“{initial.guardian.epithet}”</p>
        </header>

        <dl class="atlas-dossier-ledger">
          <div>
            <dt>Guardião</dt>
            <dd id="atlas-guardian">{initial.guardian.name}</dd>
          </div>
          <div>
            <dt>Essência</dt>
            <dd id="atlas-essence">{initial.realm.essence}</dd>
          </div>
          <div>
            <dt>Fervor</dt>
            <dd id="atlas-fervor">{initial.realm.fervor}</dd>
          </div>
          <div>
            <dt>Sovereign Gravity</dt>
            <dd id="atlas-gravity">{initial.realm.gravity}</dd>
          </div>
        </dl>

        <div class="atlas-dossier-lore">
          <span class="rubric">âncora ritual</span>
          <strong id="atlas-temple">{initial.realm.temple}</strong>
          <p id="atlas-biome">{initial.realm.biome}</p>
        </div>

        <div class="atlas-dossier-actions">
          <a id="atlas-realm-link" href={`${base}/reinos/${initial.realm.slug}/`}>Abrir fólio do Reino</a>
          <a id="atlas-guardian-link" href={`${base}/guardioes/${initial.guardian.slug}/`}>Conhecer o Guardião</a>
        </div>

        <nav class="atlas-dossier-sequence" aria-label="Navegação sequencial entre Reinos">
          <button type="button" id="atlas-previous-realm"><span aria-hidden="true">←</span> Reino anterior</button>
          <button type="button" id="atlas-next-realm">Próximo Reino <span aria-hidden="true">→</span></button>
        </nav>
      </div>
    </aside>
  </div>

  <footer class="atlas-coordinate-line" aria-hidden="true">
    <span>MAPA CANÔNICO DO CONTINENTE · v1.1</span>
    <span>ESCALA NARRATIVA · DISTÂNCIA MEDIDA POR ROTA</span>
  </footer>

  <script id="atlas-entry-data" type="application/json" set:html={serializedAtlas}></script>
</section>

<script>
  type AtlasClientEntry = {
    mapNumber: number;
    slug: string;
    realm: string;
    trueName: string;
    essence: string;
    fervor: string;
    gravity: string;
    temple: string;
    biome: string;
    guardian: string;
    guardianSlug: string;
    epithet: string;
    panorama: string;
    panoramaSrcset: string;
    emblem: string;
    realmHref: string;
    guardianHref: string;
  };

  type AtlasSelectionOptions = {
    focusPin?: boolean;
    updateHash?: boolean;
    recordVisit?: boolean;
    hover?: boolean;
  };

  function bindImmersiveAtlas() {
    const root = document.querySelector<HTMLElement>('[data-immersive-atlas]');
    if (!root || root.dataset.bound) return;
    root.dataset.bound = 'true';

    const dataNode = root.querySelector<HTMLScriptElement>('#atlas-entry-data');
    if (!dataNode?.textContent) return;
    const entries = JSON.parse(dataNode.textContent) as AtlasClientEntry[];
    const coldQaToken = new URLSearchParams(window.location.search).get('qa-cold');
    if (coldQaToken) {
      const bust = (url: string) => `${url}${url.includes('?') ? '&' : '?'}qa-cold=${encodeURIComponent(coldQaToken)}`;
      entries.forEach((entry) => {
        entry.panorama = bust(entry.panorama);
        entry.panoramaSrcset = entry.panoramaSrcset
          .split(',')
          .map((candidate) => {
            const [url, descriptor] = candidate.trim().split(/\s+/, 2);
            return `${bust(url)} ${descriptor}`;
          })
          .join(', ');
        entry.emblem = bust(entry.emblem);
      });
    }
    const pins = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-atlas-index]'));
    const listItems = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-atlas-list-index]'));
    const viewport = root.querySelector<HTMLElement>('#atlas-map-viewport')!;
    const canvas = root.querySelector<HTMLElement>('#atlas-map-canvas')!;
    const mapImage = root.querySelector<HTMLImageElement>('#atlas-map-image')!;
    const dossier = root.querySelector<HTMLElement>('#atlas-dossier')!;
    const scene = root.querySelector<HTMLElement>('#atlas-dossier-scene')!;
    const panorama = root.querySelector<HTMLImageElement>('#atlas-panorama')!;
    const emblem = root.querySelector<HTMLImageElement>('#atlas-emblem')!;
    const liveStatus = root.querySelector<HTMLElement>('#atlas-live-status')!;
    const progress = root.querySelector<HTMLElement>('#atlas-progress')!;
    const folio = root.querySelector<HTMLElement>('#atlas-folio')!;
    const title = root.querySelector<HTMLElement>('#atlas-dossier-title')!;
    const epithet = root.querySelector<HTMLElement>('#atlas-epithet')!;
    const guardian = root.querySelector<HTMLElement>('#atlas-guardian')!;
    const essence = root.querySelector<HTMLElement>('#atlas-essence')!;
    const fervor = root.querySelector<HTMLElement>('#atlas-fervor')!;
    const gravity = root.querySelector<HTMLElement>('#atlas-gravity')!;
    const temple = root.querySelector<HTMLElement>('#atlas-temple')!;
    const biome = root.querySelector<HTMLElement>('#atlas-biome')!;
    const realmLink = root.querySelector<HTMLAnchorElement>('#atlas-realm-link')!;
    const guardianLink = root.querySelector<HTMLAnchorElement>('#atlas-guardian-link')!;
    let current = 0;
    let requested = current;
    let hoverSelection = -1;
    let imageRequest = 0;
    let transitionTimer = 0;
    let transitionFrame = 0;
    type CachedImage = { image: HTMLImageElement | null; promise: Promise<void> };
    const imageCache = new Map<string, CachedImage>();
    const PANORAMA_SIZES = '(min-width: 1080px) 360px, 96vw';
    const HOVER_INTENT_MS = 80;
    const TRANSITION_MS = 440;

    function preloadImage(
      src: string,
      { srcset = '', sizes = '', priority = 'auto' }: {
        srcset?: string;
        sizes?: string;
        priority?: 'high' | 'low' | 'auto';
      } = {},
    ) {
      const key = `${src}|${srcset}|${sizes}`;
      const cached = imageCache.get(key);
      if (cached) {
        if (priority === 'high' && cached.image) cached.image.fetchPriority = 'high';
        return cached.promise;
      }

      const incoming = new Image();
      incoming.decoding = 'async';
      incoming.fetchPriority = priority;
      if (sizes) incoming.sizes = sizes;
      if (srcset) incoming.srcset = srcset;
      const record: CachedImage = { image: incoming, promise: Promise.resolve() };
      const promise = new Promise<void>((resolve, reject) => {
        incoming.onload = async () => {
          try { await incoming.decode(); } catch { /* onload já confirma um frame utilizável */ }
          resolve();
        };
        incoming.onerror = () => reject(new Error(`Falha ao carregar ${src}`));
        incoming.src = src;
      }).catch((error) => {
        imageCache.delete(key);
        throw error;
      }).finally(() => {
        record.image = null;
      });

      record.promise = promise;
      imageCache.set(key, record);
      return promise;
    }

    function preloadAtlasEntry(entry: AtlasClientEntry, priority: 'high' | 'low' | 'auto' = 'auto') {
      return Promise.all([
        preloadImage(entry.panorama, {
          srcset: entry.panoramaSrcset,
          sizes: PANORAMA_SIZES,
          priority,
        }),
        preloadImage(entry.emblem, { priority }),
      ]);
    }

    function clearPendingState() {
      pins.forEach((pin) => pin.removeAttribute('data-pending'));
      listItems.forEach((item) => item.removeAttribute('data-pending'));
      dossier.removeAttribute('aria-busy');
    }

    function markPending(index: number) {
      pins.forEach((pin, pinIndex) => pin.toggleAttribute('data-pending', pinIndex === index && index !== current));
      listItems.forEach((item, itemIndex) => item.toggleAttribute('data-pending', itemIndex === index && index !== current));
      if (index !== current) dossier.setAttribute('aria-busy', 'true');
      else dossier.removeAttribute('aria-busy');
    }

    function updateDossier(entry: AtlasClientEntry, number: string) {
      liveStatus.textContent = `${number} · ${entry.realm}`;
      progress.textContent = number;
      folio.textContent = `fólio territorial ${number}`;
      title.textContent = entry.trueName;
      epithet.textContent = `“${entry.epithet}”`;
      guardian.textContent = entry.guardian;
      essence.textContent = entry.essence;
      fervor.textContent = entry.fervor;
      gravity.textContent = entry.gravity;
      temple.textContent = entry.temple;
      biome.textContent = entry.biome;
      realmLink.href = entry.realmHref;
      guardianLink.href = entry.guardianHref;
    }

    function commitRealm(index: number, options: AtlasSelectionOptions) {
      const { focusPin = false, updateHash = true, recordVisit = false } = options;
      const entry = entries[index];
      const number = String(entry.mapNumber).padStart(2, '0');
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      window.clearTimeout(transitionTimer);
      window.cancelAnimationFrame(transitionFrame);
      root.querySelectorAll('.atlas-dossier-scene.is-outgoing').forEach((node) => node.remove());
      scene.classList.remove('is-entering', 'is-preparing');

      let outgoing: HTMLElement | null = null;
      if (!reducedMotion && index !== current) {
        outgoing = scene.cloneNode(true) as HTMLElement;
        outgoing.removeAttribute('id');
        outgoing.querySelectorAll('[id]').forEach((node) => node.removeAttribute('id'));
        outgoing.setAttribute('aria-hidden', 'true');
        outgoing.className = 'atlas-dossier-scene is-outgoing';
        scene.before(outgoing);
        scene.classList.add('is-preparing');
      }

      current = index;
      requested = index;
      hoverSelection = -1;
      pins.forEach((pin, pinIndex) => pin.setAttribute('aria-pressed', String(pinIndex === current)));
      listItems.forEach((item, itemIndex) => item.setAttribute('aria-selected', String(itemIndex === current)));
      listItems[current]?.scrollIntoView({ block: 'nearest', inline: 'center', behavior: reducedMotion ? 'auto' : 'smooth' });

      panorama.sizes = PANORAMA_SIZES;
      panorama.srcset = entry.panoramaSrcset;
      panorama.src = entry.panorama;
      panorama.alt = `Panorama editorial de ${entry.trueName}`;
      emblem.src = entry.emblem;
      emblem.alt = '';
      updateDossier(entry, number);
      clearPendingState();

      if (outgoing) {
        transitionFrame = requestAnimationFrame(() => {
          transitionFrame = requestAnimationFrame(() => {
            scene.classList.remove('is-preparing');
            scene.classList.add('is-entering');
          });
        });
        transitionTimer = window.setTimeout(() => {
          outgoing?.remove();
          scene.classList.remove('is-entering');
        }, TRANSITION_MS);
      }

      if (updateHash) history.replaceState(null, '', `#reino-${entry.slug}`);
      if (focusPin) pins[current]?.focus({ preventScroll: true });
      if (recordVisit) {
        window.dispatchEvent(new CustomEvent('roc:realm-visited', {
          detail: { slug: entry.slug, path: entry.realmHref },
        }));
      }
    }

    function selectRealm(index: number, options: AtlasSelectionOptions = {}) {
      const { focusPin = false, updateHash = true, recordVisit = false, hover = false } = options;
      const next = (index + entries.length) % entries.length;
      const entry = entries[next];
      if (next === current && requested === current) {
        hoverSelection = -1;
        if (updateHash) history.replaceState(null, '', `#reino-${entry.slug}`);
        if (focusPin) pins[current]?.focus({ preventScroll: true });
        if (recordVisit) {
          window.dispatchEvent(new CustomEvent('roc:realm-visited', {
            detail: { slug: entry.slug, path: entry.realmHref },
          }));
        }
        return;
      }

      requested = next;
      hoverSelection = hover ? next : -1;
      markPending(next);
      const request = ++imageRequest;
      preloadAtlasEntry(entry, 'high').then(() => {
        if (request !== imageRequest) return;
        commitRealm(next, { focusPin, updateHash, recordVisit });
      }).catch(() => {
        if (request !== imageRequest) return;
        requested = current;
        hoverSelection = -1;
        clearPendingState();
      });
    }

    const connection = (navigator as Navigator & {
      connection?: { saveData?: boolean; effectiveType?: string };
    }).connection;
    const saveData = connection?.saveData === true;
    const constrainedNetwork = saveData || /(^|-)2g$/.test(connection?.effectiveType || '');
    const scheduleIdle = (callback: () => void) => {
      const idleWindow = window as Window & {
        requestIdleCallback?: (handler: () => void, options?: { timeout: number }) => number;
      };
      if (idleWindow.requestIdleCallback) idleWindow.requestIdleCallback(callback, { timeout: 600 });
      else window.setTimeout(callback, 220);
    };

    function scheduleAtlasPrefetch(origin = current) {
      if (constrainedNetwork) return;
      const circularDistance = (index: number) => {
        const distance = Math.abs(index - origin);
        return Math.min(distance, entries.length - distance);
      };
      const queue = entries
        .map((_, index) => index)
        .filter((index) => index !== origin)
        .sort((a, b) => circularDistance(a) - circularDistance(b));

      const preloadBatch = () => {
        const batch = queue.splice(0, 3);
        if (!batch.length) return;
        Promise.allSettled(batch.map((index) => preloadAtlasEntry(entries[index], 'low')))
          .then(() => { if (queue.length) scheduleIdle(preloadBatch); });
      };

      scheduleIdle(preloadBatch);
    }

    let hoverTimer = 0;
    pins.forEach((pin, index) => {
      pin.addEventListener('click', () => selectRealm(index, { recordVisit: true }));
      pin.addEventListener('focus', () => selectRealm(index, { updateHash: false }));
      pin.addEventListener('pointerenter', (event) => {
        if (event.pointerType !== 'mouse' || saveData) return;
        window.clearTimeout(hoverTimer);
        hoverTimer = window.setTimeout(() => selectRealm(index, { updateHash: false, hover: true }), HOVER_INTENT_MS);
      });
      pin.addEventListener('pointerleave', () => {
        window.clearTimeout(hoverTimer);
        if (hoverSelection === index && requested === index && requested !== current) {
          imageRequest += 1;
          requested = current;
          hoverSelection = -1;
          clearPendingState();
        }
      });
    });
    listItems.forEach((item, index) => item.addEventListener('click', () => selectRealm(index, { recordVisit: true })));
    root.querySelector('#atlas-previous-realm')?.addEventListener('click', () => selectRealm(requested - 1, { recordVisit: true }));
    root.querySelector('#atlas-next-realm')?.addEventListener('click', () => selectRealm(requested + 1, { recordVisit: true }));

    root.addEventListener('keydown', (event) => {
      const target = event.target as HTMLElement;
      if (!target.matches('[data-atlas-index], [data-atlas-list-index]')) return;
      if (!['ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown', 'Home', 'End'].includes(event.key)) return;
      event.preventDefault();
      if (event.key === 'Home') selectRealm(0, { focusPin: target.hasAttribute('data-atlas-index'), recordVisit: true });
      else if (event.key === 'End') selectRealm(entries.length - 1, { focusPin: target.hasAttribute('data-atlas-index'), recordVisit: true });
      else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') selectRealm(requested - 1, { focusPin: target.hasAttribute('data-atlas-index'), recordVisit: true });
      else selectRealm(requested + 1, { focusPin: target.hasAttribute('data-atlas-index'), recordVisit: true });
      if (target.hasAttribute('data-atlas-list-index')) listItems[requested]?.focus({ preventScroll: true });
    });

    let scale = 1;
    let translateX = 0;
    let translateY = 0;
    const minScale = 1;
    const maxScale = 3;
    let highResolutionLoaded = false;

    function loadHighResolutionMap() {
      if (highResolutionLoaded || !mapImage.dataset.hires || saveData) return;
      highResolutionLoaded = true;
      const incoming = new Image();
      incoming.decoding = 'async';
      incoming.onload = () => { mapImage.src = mapImage.dataset.hires || mapImage.src; };
      incoming.src = mapImage.dataset.hires;
    }

    function clampMap() {
      const width = canvas.offsetWidth * scale;
      const height = canvas.offsetHeight * scale;
      translateX = Math.min(0, Math.max(viewport.clientWidth - width, translateX));
      translateY = Math.min(0, Math.max(viewport.clientHeight - height, translateY));
      if (scale === 1) {
        translateX = 0;
        translateY = 0;
      }
    }

    function renderMap() {
      clampMap();
      canvas.style.transform = `translate3d(${translateX}px, ${translateY}px, 0) scale(${scale})`;
      viewport.dataset.zoomed = String(scale > 1.01);
    }

    function zoomAt(clientX: number, clientY: number, factor: number) {
      const bounds = viewport.getBoundingClientRect();
      const pointX = clientX - bounds.left;
      const pointY = clientY - bounds.top;
      const nextScale = Math.min(maxScale, Math.max(minScale, scale * factor));
      translateX = pointX - (pointX - translateX) * (nextScale / scale);
      translateY = pointY - (pointY - translateY) * (nextScale / scale);
      scale = nextScale;
      if (scale > 1.08) loadHighResolutionMap();
      renderMap();
    }

    function zoomFromCenter(factor: number) {
      const bounds = viewport.getBoundingClientRect();
      zoomAt(bounds.left + bounds.width / 2, bounds.top + bounds.height / 2, factor);
    }

    root.querySelector('#atlas-zoom-in')?.addEventListener('click', () => zoomFromCenter(1.35));
    root.querySelector('#atlas-zoom-out')?.addEventListener('click', () => zoomFromCenter(1 / 1.35));
    root.querySelector('#atlas-zoom-reset')?.addEventListener('click', () => {
      scale = 1;
      translateX = 0;
      translateY = 0;
      renderMap();
    });

    viewport.addEventListener('wheel', (event) => {
      if (!event.ctrlKey && !event.metaKey) return;
      event.preventDefault();
      zoomAt(event.clientX, event.clientY, event.deltaY < 0 ? 1.16 : 1 / 1.16);
    }, { passive: false });

    viewport.addEventListener('keydown', (event) => {
      if (event.target !== viewport) return;
      if (event.key === '+' || event.key === '=') {
        event.preventDefault();
        zoomFromCenter(1.3);
      } else if (event.key === '-') {
        event.preventDefault();
        zoomFromCenter(1 / 1.3);
      } else if (event.key === '0' || event.key === 'Escape') {
        event.preventDefault();
        scale = 1;
        translateX = 0;
        translateY = 0;
        renderMap();
      }
    });

    let dragging = false;
    let previousX = 0;
    let previousY = 0;
    viewport.addEventListener('pointerdown', (event) => {
      if (scale <= 1.01 || (event.target as HTMLElement).closest('button, a')) return;
      dragging = true;
      previousX = event.clientX;
      previousY = event.clientY;
      viewport.classList.add('is-dragging');
      viewport.setPointerCapture(event.pointerId);
    });
    viewport.addEventListener('pointermove', (event) => {
      if (!dragging) return;
      translateX += event.clientX - previousX;
      translateY += event.clientY - previousY;
      previousX = event.clientX;
      previousY = event.clientY;
      renderMap();
    });
    const stopDragging = () => {
      dragging = false;
      viewport.classList.remove('is-dragging');
    };
    viewport.addEventListener('pointerup', stopDragging);
    viewport.addEventListener('pointercancel', stopDragging);
    viewport.addEventListener('lostpointercapture', stopDragging);
    new ResizeObserver(renderMap).observe(viewport);

    const hashSlug = location.hash.replace('#reino-', '');
    const fromHash = entries.findIndex((entry) => entry.slug === hashSlug);
    if (fromHash >= 0) selectRealm(fromHash, { updateHash: false });
    if (!coldQaToken) scheduleAtlasPrefetch(fromHash >= 0 ? fromHash : current);
  }

  document.addEventListener('astro:page-load', bindImmersiveAtlas);
</script>

