---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname;
const isRealms = path.includes('/reinos');
const isSystems = path.includes('/sistemas');
const isAtlas = path.includes('/atlas');
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href={`${base}/`}>REALM OF CRESTS</a>
    <nav class="site-nav" aria-label="Navegação principal">
      <a href={`${base}/`} aria-current={!isRealms && !isSystems && !isAtlas ? 'page' : undefined}>Manifesto</a>
      <a href={`${base}/reinos/`} aria-current={isRealms ? 'page' : undefined}>Os Dezenove Reinos</a>
      <a href={`${base}/sistemas/`} aria-current={isSystems ? 'page' : undefined}>Sistemas</a>
      <a href={`${base}/atlas/`} aria-current={isAtlas ? 'page' : undefined}>Atlas</a>
    </nav>
  </div>
</header>
