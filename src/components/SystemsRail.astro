---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname;
const cur = (seg: string) => (path.includes(`/sistemas/${seg}`) ? 'page' : undefined);
---
<nav class="systems-rail" aria-label="Capítulos de sistemas">
  <div class="wrap">
    <a href={`${base}/sistemas/fervor/`} aria-current={cur('fervor')}>LIVRO II · FERVOR</a>
    <a href={`${base}/sistemas/gravity/`} aria-current={cur('gravity')}>SOVEREIGN GRAVITY</a>
    <a href={`${base}/sistemas/ascensao/`} aria-current={cur('ascensao')}>ASCENSÃO</a>
  </div>
</nav>
