---
import { fervorSignature } from '../lib/fervor.js';

interface Props {
  realm: {
    slug: string;
    realm: string;
    epithet: string;
    guardian: string;
    order: number;
    fervor?: string;
  };
}

const { realm } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const folio = String(realm.order).padStart(2, '0');
const fv = fervorSignature(realm.fervor);
---
<li class="reveal">
  <a
    class={`realm-card fv-${fv.key}`}
    href={`${base}/reinos/${realm.slug}/`}
    style={`--fv: ${fv.color}; --fv-soft: ${fv.soft};`}
  >
    <span class="folio">FOLIO {folio}/19</span>
    <img
      src={`${base}/assets/emblems/emblem_${realm.slug}.webp`}
      alt={`Brasão do Reino de ${realm.realm}`}
      loading="lazy"
      width="128"
      height="128"
      transition:name={`emblem-${realm.slug}`}
      onerror={`this.onerror=null;this.src='${base}/assets/emblems/placeholder.svg'`}
    />
    <h3>{realm.realm}</h3>
    <p class="epithet">“{realm.epithet}”</p>
    <p class="guardian-line">{realm.guardian}</p>
  </a>
</li>
