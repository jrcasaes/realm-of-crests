---
import { canonLabel, loreMasterLabel, dossierLabel } from '../../lib/canon.js';
import BaseLayout from '../../layouts/BaseLayout.astro';
import RealmPanorama from '../../components/RealmPanorama.astro';
import realms from '../../data/realms.json';
import { fervorSignature, parseFervorField } from '../../lib/fervor.js';
import ContinuityEcho from '../../components/ContinuityEcho.astro';

export function getStaticPaths() {
  return realms.map((realm) => ({
    params: { slug: realm.slug },
    props: { realm },
  }));
}

const { realm } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const folio = String(realm.order).padStart(2, '0');
const fv = fervorSignature(realm.fervor);
const fervorRelations = parseFervorField(realm.fervor);
const guardianSlug = realm.guardian.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();

const idx = realms.findIndex((r) => r.slug === realm.slug);
const prev = realms[(idx - 1 + realms.length) % realms.length];
const next = realms[(idx + 1) % realms.length];
---
<BaseLayout title={`${realm.trueName} — Realm of Crests`} description={`${realm.trueName}, “${realm.epithet}”. Guardião: ${realm.guardian}.`}>
  <article class="realm-page" style={`--fv: ${fv.color}; --fv-soft: ${fv.soft};`}>
    <div class="wrap">
      <nav class="breadcrumb rubric" aria-label="Trilha">
        <a href={`${base}/reinos/#reino-${realm.slug}`}>← atlas soberano</a>
      </nav>

      <RealmPanorama realm={realm} />

      <div class="realm-layout">
        <figure class="emblem-frame" style="margin: 0;">
          <img
            src={`${base}/assets/emblems/emblem_${realm.slug}.webp`}
            alt={`Brasão canônico do ${realm.trueName}`}
            width="800"
            height="800"
            transition:name={`emblem-${realm.slug}`}
            onerror={`this.onerror=null;this.src='${base}/assets/emblems/placeholder.svg'`}
          />
          <figcaption class="folio">FOLIO {folio}/19</figcaption>
        </figure>

        <p class="crest-reading"><span class="rubric" style="display:block; margin-bottom:0.5rem;">leitura canônica do brasão · cc-26</span>{realm.crestReading}</p>

        <div>
          <header class="realm-head">
            <span class="rubric">reino nº {folio} · {canonLabel}</span>
            <h1>{realm.trueName}</h1>
            <p class="epithet">“{realm.epithet}”</p>
            <p class="guardian-line">Guardião: <a href={`${base}/guardioes/${guardianSlug}/`}>{realm.guardian}</a>{realm.guardianVulgo ? ` — ${realm.guardianVulgo}` : ''}</p>
          </header>

          <dl class="systems">
            <div>
              <dt>Essence</dt>
              <dd>{realm.essence}</dd>
            </div>
            <div>
              <dt>Fervor</dt>
              <dd class="fervor-links">
                {fervorRelations.map((relation) => (
                  <a href={`${base}/sistemas/fervor/#fervor-${relation.id}`}>
                    <span>Fervor de {relation.label}</span>
                    <small>{relation.role}</small>
                  </a>
                ))}
              </dd>
            </div>
            <div>
              <dt>Gravity</dt>
              <dd>{realm.gravity}</dd>
            </div>
            <div>
              <dt>Âncora territorial</dt>
              <dd>{realm.temple}</dd>
            </div>
          </dl>

          <ContinuityEcho currentRealm={realm} mode="realm" />

          <div class="layers">
            <table>
              <caption>nomenclatura ao longo das eras</caption>
              <tbody>
                <tr><td>Nome Verdadeiro</td><td>{realm.trueName}</td></tr>
                {realm.historicalAlias && <tr><td>Alcunha Histórica</td><td>{realm.historicalAlias}</td></tr>}
                {realm.territorialEcho && <tr><td>Eco Territorial</td><td>{realm.territorialEcho}</td></tr>}
                {realm.guardianEcho && <tr><td>Guardião — Eco Ancestral</td><td>{realm.guardianEcho}</td></tr>}
                {realm.guardianVulgo && <tr><td>Guardião — Vulgo da Multidão</td><td>{realm.guardianVulgo}</td></tr>}
                {realm.battleEcho && <tr><td>Guardião — Eco das Batalhas</td><td>{realm.battleEcho}</td></tr>}
              </tbody>
            </table>
          </div>

          <section class="lore-block">
            <h2>Geografia &amp; Bioma</h2>
            <p>{realm.biome}.</p>
          </section>

          <section class="lore-block">
            <h2>Templo</h2>
            <p><span class="temple-name">{realm.temple}</span> — {realm.templeDesc}.</p>
          </section>

          <p class="source-line rubric">{`fontes: ${dossierLabel} · ${loreMasterLabel} · cc-26 — revisão canônica: ${realm.lastCanonReview}`}</p>

          <nav class="realm-nav" aria-label="Navegação entre reinos">
            <a href={`${base}/reinos/${prev.slug}/`}>← {prev.realm}</a>
            <a href={`${base}/reinos/${next.slug}/`}>{next.realm} →</a>
          </nav>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
