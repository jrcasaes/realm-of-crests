---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OrnamentDivider from '../../components/OrnamentDivider.astro';
import RealmAtlasExplorer from '../../components/RealmAtlasExplorer.astro';
---
<BaseLayout
  title="Atlas Soberano dos Dezenove Reinos — Realm of Crests"
  description="Explore os dezenove Reinos de Realm of Crests por seus panoramas habitados, Guardiões, biomas e templos."
>
  <div class="page-head sovereign-page-head">
    <span class="rubric">atlas soberano · arquivo visual</span>
    <h1>OS DEZENOVE REINOS</h1>
    <p class="lede">Um continente, dezenove soberanias. Percorra as cidades, fortalezas, rotas e templos que transformam cada território em um mundo habitado.</p>
  </div>

  <OrnamentDivider />

  <div class="wide-wrap sovereign-atlas-wrap">
    <RealmAtlasExplorer />
  </div>
</BaseLayout>
