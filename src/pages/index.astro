---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrnamentDivider from '../components/OrnamentDivider.astro';
import RealmCard from '../components/RealmCard.astro';
import realms from '../data/realms.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Realm of Crests — O Codex dos Dezenove Reinos">
  <section class="hero-banner">
    <img
      src={`${base}/assets/heroes/hero_victoria.webp`}
      srcset={`${base}/assets/heroes/hero_victoria.webp 1688w, ${base}/assets/heroes/hero_victoria_2x.webp 3376w`}
      sizes="100vw"
      alt="O Silêncio do Desfiladeiro — o Obelisco de basalto aceso em brasas âmbar diante da Fortaleza escavada no cânion"
      width="3376"
      height="1440"
      fetchpriority="high"
    />
    <div class="hero-inner">
      <span class="rubric">codex oficial · canon v3.0.2</span>
      <h1>REALM <span class="gilt">of</span> CRESTS</h1>
      <p class="manifesto">
        Dezenove reinos. Dezenove Guardiões. Cada trono sustentado por uma Emberline
        que não pode se romper — e cada Guardião moldado pelo Fervor de seu povo,
        sob o peso da Sovereign Gravity. Este é o arquivo do mundo: abra os folios.
      </p>
    </div>
    <span class="hero-credit">O SILÊNCIO DO DESFILADEIRO · v2.0 · APROVADO</span>
  </section>

  <OrnamentDivider />

  <section class="realms-section">
    <div class="wrap">
      <span class="rubric">os dezenove reinos</span>
      <ul class="realm-grid">
        {realms.map((realm) => <RealmCard realm={realm} />)}
      </ul>
    </div>
  </section>
</BaseLayout>

<script>
  function bindReveal() {
    const items = document.querySelectorAll('.reveal:not(.is-visible)');
    if (!items.length) return;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).style.transitionDelay = `${(i % 6) * 60}ms`;
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    items.forEach((el) => io.observe(el));
  }
  document.addEventListener('astro:page-load', bindReveal);
</script>
