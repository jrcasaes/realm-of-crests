---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="QA responsivo — Realm of Crests"
  description="Quadro temporário e não indexável para validar a prévia responsiva da Fase 6.1."
>
  <section class="qa-responsive" data-base={base} aria-labelledby="qa-title">
    <h1 id="qa-title">QA RESPONSIVO</h1>
    <p id="qa-status">Preparando quadro de QA…</p>
    <div id="qa-stage"></div>

    <script is:inline>
      const allowed = new Set([320, 375, 390, 768, 1920]);
      const requested = Number(new URLSearchParams(location.search).get('vp'));
      const width = allowed.has(requested) ? requested : 320;
      const base = document.querySelector('.qa-responsive').dataset.base;
      const frame = document.createElement('iframe');
      frame.dataset.qaViewport = String(width);
      frame.title = `Atlas em ${width} pixels`;
      frame.src = `${base}/atlas/?qa=responsive-${width}`;
      frame.style.width = `${width}px`;
      frame.style.height = '1050px';
      frame.addEventListener('load', () => {
        document.getElementById('qa-status').textContent = `Atlas renderizado em ${width} px`;
      }, { once: true });
      document.getElementById('qa-stage').append(frame);
    </script>
  </section>
</BaseLayout>

<style>
  :global(*) { box-sizing: border-box; }
  .qa-responsive { width: max-content; min-width: 100%; min-height: 100vh; padding: 12px; color: #d7c49a; background: #111; font: 14px/1.4 system-ui, sans-serif; }
  h1 { margin: 0 0 8px; font-size: 1rem; }
  p { margin: 0 0 8px; }
  iframe { display: block; border: 2px solid #9b7128; background: #000; }
</style>
